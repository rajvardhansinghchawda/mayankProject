# SARAS — Environment Configuration Template
# Copy this file to .env in the project root and fill in values
# ⚠️  NEVER commit .env to version control

# ============================================================
# DJANGO CORE
# ============================================================
DJANGO_SECRET_KEY=CHANGE-THIS-TO-A-64-CHAR-RANDOM-STRING-aabbccddeeff1122334455667788
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# ============================================================
# POSTGRESQL
# ============================================================
DB_NAME=saras_db
DB_USER=saras_user
DB_PASSWORD=saras_dev_password
DB_HOST=localhost
DB_PORT=5432

# ============================================================
# REDIS
# ============================================================
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2
WEBSOCKET_CHANNEL_DB=redis://localhost:6379/3

# ============================================================
# FASTAPI REAL-TIME SERVICE
# ============================================================
FASTAPI_HOST=0.0.0.0
FASTAPI_PORT=8001
FASTAPI_SECRET_KEY=SAME-AS-DJANGO-SECRET-KEY

# ============================================================
# JWT SETTINGS
# ============================================================
JWT_ACCESS_TOKEN_EXPIRY_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRY_DAYS=7
SERVE_TOKEN_EXPIRY_MINUTES=5

# ============================================================
# FILE CONSTRAINTS
# ============================================================
MAX_UPLOAD_SIZE_BYTES=2097152

# ============================================================
# CELERY WORKER
# ============================================================
CELERY_WORKER_CONCURRENCY=4
CELERY_TASK_TIME_LIMIT=300

# ============================================================
# EMAIL (use console backend for local dev)
# ============================================================
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=noreply@saras.local

# ============================================================
# INSTITUTION
# ============================================================
INSTITUTION_NAME=SARAS Institution

# ============================================================
# CORS (add your frontend URL here)
# ============================================================
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
